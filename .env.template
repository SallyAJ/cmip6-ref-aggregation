# CDS (Copernicus Climate Data Store) API
# Obtain your key at https://cds.climate.copernicus.eu/user/login
CDS_API_URL=https://cds.climate.copernicus.eu/api
CDS_API_KEY=your-cds-api-key-here
# Path to the CDS API credentials file (default: ~/.cdsapirc)
CDS_API_RC_PATH=~/.cdsapirc

# CHIRPS data download base URL
CHIRPS_URL=https://data.chc.ucsb.edu/products/CHIRPS/v3.0/daily/final/ERA5/

# Cluster / server storage root (absolute path to the shared data directory)
DATA_DIR_CENTRE=/mnt/Climate/DataCentre/data

